# Anthropic API key for Claude Sonnet (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Neo4j connection (required)
# For Neo4j Desktop: bolt://localhost:7687
# For AuraDB Free: neo4j+s://xxxxx.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# LLM model name (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# Embedding model for ChromaDB vector store
# Uses sentence-transformers locally (no extra API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB local persistence directory (created automatically)
CHROMA_PERSIST_DIR=./chroma_store/

# Contradiction guard mode: permissive (dev) or strict (eval/prod)
GUARD_MODE=permissive

# OpenTelemetry configuration
OTEL_SERVICE_NAME=lorekeeper
# console = print traces to stdout (dev), otlp = export to collector (prod)
OTEL_EXPORTER=console

# Environment flag
APP_ENV=development
